---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Media"
  description="Watch Joshuacord's documentary films and explore media resources about persecuted Christians worldwide."
>

  <!-- PAGE HERO -->
  <section class="relative bg-dark py-28 overflow-hidden">
    <div class="absolute inset-0 opacity-20">
      <img
        src="https://christiansinthemirror.com/wp-content/uploads/2020/04/poster_v2-300x170.jpg"
        alt=""
        class="w-full h-full object-cover object-center"
      />
    </div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-clay text-sm font-medium tracking-[0.2em] uppercase mb-4">Films & Media</p>
      <h1 class="font-display text-5xl sm:text-6xl text-white mb-5">Media</h1>
      <div class="w-12 h-0.5 bg-brand mx-auto mb-6"></div>
      <p class="text-white/65 text-lg leading-relaxed max-w-2xl mx-auto">
        Joshuacord produces documentary films that give voice to persecuted believers
        and challenge the Western church to see beyond its comfort.
      </p>
    </div>
  </section>

  <!-- FILM 1: CHRISTIANS IN THE MIRROR -->
  <section class="py-24 bg-sand">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Priority badge -->
      <div class="flex items-center gap-3 mb-10">
        <div class="w-1 h-10 bg-brand"></div>
        <div>
          <p class="text-brand text-xs font-medium tracking-[0.2em] uppercase">Featured Film</p>
          <h2 class="font-display text-3xl text-dark">Christians in the Mirror</h2>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 items-start">

        <!-- Video embed (3/5 width) -->
        <div class="lg:col-span-3">
          <div class="relative w-full" style="padding-top: 56.25%;">
            <iframe
              class="absolute inset-0 w-full h-full"
              src="https://www.youtube.com/embed/LYfMCer0_tU"
              title="Christians in the Mirror"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            ></iframe>
          </div>
        </div>

        <!-- Film details (2/5 width) -->
        <div class="lg:col-span-2 space-y-5">
          <img
            src="https://christiansinthemirror.com/wp-content/uploads/2020/04/poster_v2-300x170.jpg"
            alt="Christians in the Mirror poster"
            class="w-full max-w-xs shadow-lg"
          />

          <div class="space-y-4 text-sm text-dark/70 leading-relaxed">
            <p>
              An expository documentary that takes viewers into the lives of persecuted Christians
              in Syria, Iraq, India, South Sudan, and Egypt — and holds a mirror to the comfortable,
              affluent Western church. Directed by Jordan Allott.
            </p>
            <p>
              Featured individuals include Ibitsam (Egypt), Pastor Nehemiah (India),
              Antione (Syria), Rev. John (Sudan), and Um Rama (Jordan / Iraq).
            </p>
          </div>

          <div class="space-y-2 pt-2">
            <p class="text-xs text-dark/50 uppercase tracking-wide font-medium">Available On</p>
            <div class="flex flex-wrap gap-3">
              <a
                href="https://www.christiancinema.com/digital/movie/christians-in-the-mirror"
                target="_blank"
                rel="noopener noreferrer"
                class="bg-sand-dark border border-clay/30 hover:border-brand text-dark hover:text-brand text-xs font-medium px-4 py-2 transition-colors"
              >
                Christian Cinema
              </a>
              <a
                href="https://christiansinthemirror.com"
                target="_blank"
                rel="noopener noreferrer"
                class="bg-sand-dark border border-clay/30 hover:border-brand text-dark hover:text-brand text-xs font-medium px-4 py-2 transition-colors"
              >
                Official Site
              </a>
            </div>
          </div>

          <div class="border-t border-clay/20 pt-5 space-y-2">
            <p class="text-xs text-dark/50 uppercase tracking-wide font-medium">Host a Screening</p>
            <p class="text-xs text-dark/65 leading-relaxed">
              Bring <em>Christians in the Mirror</em> to your church, school, or community.
              Screening applications are available at the official site.
            </p>
            <a
              href="https://christiansinthemirror.com"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-block text-brand hover:text-brand-dark text-xs font-medium transition-colors"
            >
              Request a screening →
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- DIVIDER -->
  <div class="h-px bg-clay/20 max-w-7xl mx-auto"></div>

  <!-- FILM 2: MY RIPPLE EFFECT -->
  <section class="py-24 bg-sand">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="flex items-center gap-3 mb-10">
        <div class="w-1 h-10 bg-clay"></div>
        <div>
          <p class="text-clay text-xs font-medium tracking-[0.2em] uppercase">Documentary Film</p>
          <h2 class="font-display text-3xl text-dark">My Ripple Effect</h2>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 items-start">

        <!-- Video embed -->
        <div class="lg:col-span-3">
          <div class="relative w-full" style="padding-top: 56.25%;">
            <iframe
              class="absolute inset-0 w-full h-full"
              src="https://www.youtube.com/embed/Akmjc0ijEyk"
              title="My Ripple Effect"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            ></iframe>
          </div>
        </div>

        <!-- Details -->
        <div class="lg:col-span-2 space-y-5 text-sm text-dark/70 leading-relaxed">
          <p>
            <em>My Ripple Effect</em> is a Joshuacord documentary that explores how individual acts
            of faith and compassion create lasting change — rippling outward into communities,
            nations, and generations.
          </p>
          <p>
            The film invites viewers to consider their own potential to impact the persecuted
            church by taking action, no matter how small it may seem.
          </p>
          <div class="pt-2">
            <a
              href="https://youtu.be/Akmjc0ijEyk"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-block bg-brand hover:bg-brand-dark text-white px-5 py-2.5 text-xs font-medium tracking-wide transition-colors"
            >
              Watch on YouTube
            </a>
          </div>
          <div class="border-t border-clay/20 pt-4">
            <p class="text-xs text-dark/50">
              Share your own ripple at{' '}
              <a
                href="https://www.myrippleeffect.org/themovie"
                target="_blank"
                rel="noopener noreferrer"
                class="text-brand hover:underline"
              >
                myrippleeffect.org
              </a>
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- DIVIDER -->
  <div class="h-px bg-clay/20 max-w-7xl mx-auto"></div>

  <!-- MUSIC: NEW SONG -->
  <section class="py-24 bg-sand-dark">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="flex items-center gap-3 mb-10">
        <div class="w-1 h-10 bg-earth"></div>
        <div>
          <p class="text-earth text-xs font-medium tracking-[0.2em] uppercase">Music</p>
          <h2 class="font-display text-3xl text-dark">New Song</h2>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center max-w-4xl">
        <div class="space-y-5 text-sm text-dark/70 leading-relaxed">
          <p>
            <em>New Song</em> is a musical project from Joshuacord — a collection of worship
            that reflects the faith of persecuted believers around the world. <em>The Lord Jesus is Coming</em>
            is available to stream on Hungama Music.
          </p>
          <p>
            Music has always been the language of the persecuted church. Even in hiding, even in
            prison, even under threat, believers sing. This music is an invitation to join them.
          </p>
          <a
            href="https://www.hungama.com/album/the-lord-jesus-is-coming/59685463/"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 bg-dark hover:bg-brand text-white px-6 py-3 text-xs font-medium tracking-wide transition-colors"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3" />
            </svg>
            Listen on Hungama Music
          </a>
        </div>

        <!-- Music visual placeholder -->
        <div class="bg-dark/10 border border-clay/30 p-10 text-center">
          <div class="w-16 h-16 bg-brand/15 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3" />
            </svg>
          </div>
          <p class="font-display text-xl text-dark mb-1">New Song</p>
          <p class="text-clay text-sm italic">"The Lord Jesus is Coming"</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SOCIAL / FOLLOW CTA -->
  <section class="py-16 bg-dark">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-display text-3xl text-white mb-4">Stay Connected</h2>
      <p class="text-white/60 mb-8 leading-relaxed text-sm">
        Follow Joshuacord on social media for updates on new media, mission field news,
        and ways to take action.
      </p>
      <div class="flex items-center justify-center gap-5">
        <a
          href="https://www.facebook.com/joshuacord1.9"
          target="_blank"
          rel="noopener noreferrer"
          class="border border-white/20 hover:border-clay text-white/70 hover:text-clay px-6 py-3 text-sm font-medium tracking-wide transition-colors"
        >
          Facebook
        </a>
        <a
          href="https://twitter.com/joshua_cord"
          target="_blank"
          rel="noopener noreferrer"
          class="border border-white/20 hover:border-clay text-white/70 hover:text-clay px-6 py-3 text-sm font-medium tracking-wide transition-colors"
        >
          Twitter
        </a>
      </div>
    </div>
  </section>

</Layout>
